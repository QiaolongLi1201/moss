{
  "name": "@rdk-moss/memory",
  "version": "0.3.14",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "D-Moss Memory: context-aware memory selection and self-learning memory draft generation for agent runtime.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QiaolongLi1201/moss.git",
    "directory": "packages/dmoss-memory"
  },
  "bugs": {
    "url": "https://github.com/QiaolongLi1201/moss/issues"
  },
  "homepage": "https://github.com/QiaolongLi1201/moss/tree/main/packages/dmoss-memory#readme",
  "scripts": {
    "prebuild": "npm run build --workspace @rdk-moss/core",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "npm run build && node ../../scripts/run-package-tests.mjs"
  },
  "dependencies": {
    "@rdk-moss/core": "^0.3.14"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "keywords": [
    "dmoss",
    "memory",
    "context-selector",
    "self-learning",
    "agent",
    "robotics"
  ]
}

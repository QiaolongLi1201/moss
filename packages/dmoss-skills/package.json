{
  "name": "@dmoss/skills",
  "version": "0.3.1",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "D-Moss Skills: conversation skill learning pipeline — candidate store, scorer, distiller, promoter, and skill validation.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "src", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/QiaolongLi1201/moss.git",
    "directory": "packages/dmoss-skills"
  },
  "bugs": {
    "url": "https://github.com/QiaolongLi1201/moss/issues"
  },
  "homepage": "https://github.com/QiaolongLi1201/moss/tree/main/packages/dmoss-skills#readme",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "npm run build && node ../../scripts/run-package-tests.mjs"
  },
  "dependencies": {
    "@dmoss/core": "^0.3.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "keywords": ["dmoss", "skills", "skill-learning", "conversation-skill", "agent", "robotics"]
}

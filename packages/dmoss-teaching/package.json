{
  "name": "@rdk-moss/teaching",
  "version": "0.3.25",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "D-Moss Teaching: teach-while-solve annotation layer — pre/post teaching hooks, annotation collector, and tool digest utilities.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D-Robotics/moss.git",
    "directory": "packages/dmoss-teaching"
  },
  "bugs": {
    "url": "https://github.com/D-Robotics/moss/issues"
  },
  "homepage": "https://github.com/D-Robotics/moss/tree/main/packages/dmoss-teaching#readme",
  "scripts": {
    "prebuild": "npm run build --workspace @rdk-moss/agent && npm run build --workspace @rdk-moss/skills",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "npm run build && node ../../scripts/run-package-tests.mjs"
  },
  "dependencies": {
    "@rdk-moss/agent": "^0.3.25",
    "@rdk-moss/skills": "^0.3.25"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "keywords": [
    "dmoss",
    "teaching",
    "teach-while-solve",
    "annotation",
    "agent",
    "robotics"
  ]
}
